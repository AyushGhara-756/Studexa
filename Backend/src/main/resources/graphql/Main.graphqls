type Query {
    student(id: ID): Student
    getAssignments(studentId: ID): [Assignment]
}

type Mutation{
    addAssignment(name: String!, description: String, studentId: ID!): Boolean
}

type Student {
    id: ID
    user: User
    assignments: [Assignment]
}

type User {
    id: ID
    name: String
    email: String
    role: String
}

type Assignment {
    id: ID
    name: String
    description: String
}